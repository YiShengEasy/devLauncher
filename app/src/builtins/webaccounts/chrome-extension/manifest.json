{
  "manifest_version": 3,
  "name": "DevLauncher Web Accounts",
  "description": "Fill DevLauncher web account bindings in Google Chrome.",
  "version": "0.1.0",
  "permissions": ["nativeMessaging", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "DevLauncher Web Accounts"
  }
}
